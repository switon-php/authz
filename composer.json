{
    "name": "switon/authz",
    "description": "Permission-based authorization with attributes, voters, and role-to-permission lookup for Switon Framework",
    "type": "library",
    "keywords": [
        "switon",
        "authorization",
        "rbac",
        "policies"
    ],
    "homepage": "https://github.com/switon-php/authz",
    "license": "MIT",
    "authors": [
        {
            "name": "switon",
            "email": "admin@switon.dev"
        }
    ],
    "support": {
        "source": "https://github.com/switon-php/authz",
        "issues": "https://github.com/switon-php/authz/issues",
        "docs": "https://docs.switon.dev/latest/authz"
    },
    "require": {
        "php": ">=8.3",
        "switon/core": "^1.0",
        "switon/event": "^1.0",
        "switon/http": "^1.0",
        "switon/principal": "^1.0",
        "switon/router": "^1.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "switon/testing": "^1.0",
        "phpstan/extension-installer": "^1.4"
    },
    "config": {
        "allow-plugins": {
            "switon/composer-extra": true,
            "phpstan/extension-installer": true
        }
    },
    "autoload": {
        "psr-4": {
            "Switon\\Authorizing\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Switon\\Authorizing\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "phpstan": "@php vendor/bin/phpstan analyse",
        "test": "@php vendor/bin/phpunit --configuration tests/phpunit.xml.dist --testsuite=all --display-deprecations --display-phpunit-notices"
    },
    "extra": {
        "switon": {
            "providers": [
                "Switon\\Authorizing\\ServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-dev": "1.0.x-dev"
        }
    }
}
